# --- Stage 1: Build the static site with Grafana's real theme ---
#
# Toolchain: grafana/grafana's docs/ Makefile builds/previews docs.grafana.com by
# running the PUBLIC `grafana/docs-base` container (the same one `make docs`
# uses locally), which bundles a real Hugo install + the actual grafana.com
# layouts/shortcodes and mounts docs/sources at
# /hugo/content/docs/grafana/latest. Its own internal Makefile has a `hugo`
# target (`hugo --destination=dist/ ...`) that emits genuine STATIC HTML, so no
# "hugo server" workaround is required -- see docs/README.md and docs/docs.mk in
# grafana/grafana, and `docker run --rm --entrypoint sh grafana/docs-base:latest`
# to inspect /hugo/Makefile directly.
#
# Scope: single "latest" version only (matches the grafana/grafana main branch
# docs/sources tree), not the full grafana.com multi-version/multi-product site.
FROM grafana/docs-base:latest AS builder

WORKDIR /hugo

# Replace the image's placeholder grafana/latest content (small test fixtures
# shipped for docs-base's own CI) with the real docs/sources tree checked out by
# the workflow at grafana-src/docs/sources. Drop the "next" placeholder too so
# only "latest" gets built.
RUN rm -rf content/docs/grafana/latest content/docs/grafana/next
COPY grafana-src/docs/sources content/docs/grafana/latest

# Build static HTML.
#
# HUGO_ENV=docs is required, not optional: the theme's styles.html/scripts.html/
# build-scripts.html partials call `resources.Get "scss/main.scss"` /
# `resources.Get "js/main.js"` when HUGO_ENV != docs, and those source assets
# only exist in the private grafana/website repo -- NOT in this public image --
# so any other HUGO_ENV value fails the build outright (nil resource). HUGO_ENV
# =docs takes the "docs preview" branch instead: it emits real static HTML/CSS
# class markup for every page (menus, sidebar, admonitions, tables, etc. all
# come from local Hugo templates and render fine), but points its handful of
# theme CSS/JS <link>/<script> tags at https://grafana.com/web/... to avoid
# rebuilding this image every time the marketing site's bundle changes ("Avoid
# having to rebuild the docs base image every time the JS changes", per
# layouts/partials/scripts.html). BASE_URL=/ makes every generated permalink
# root-relative (canonifyURLs+relativeURLs=false in config/_default/config.yaml
# would otherwise bake in https://grafana.com/), which is what lets us serve the
# result from nginx with no link rewriting.
RUN make hugo HUGO_ENV=docs BASE_URL=/

# --- Vendor every external asset the "docs" theme branch depends on ---
#
# grafana.com/web/{app,banner,marked,marketing-ui}.{css,js} are the compiled
# marketing-site bundles; docs-base intentionally does not ship them locally
# (see comment above). We fetch the CSS once here at build time (this repo's
# established vendoring pattern -- see stackable-tech/Dockerfile vendoring
# Mermaid, kubernetes-io/Dockerfile vendoring Open Sans/KaTeX/jQuery) and point
# the HTML at the local copies. The JS bundles are NOT vendored: they are
# minified, come bundled with Rudderstack/Hotjar/Google Analytics/Marketo/Adobe
# Target analytics init code we have no reliable way to audit or strip out of a
# webpack bundle, and dropping them is a deliberate call -- see the "no
# external JS" note below for what that costs functionally and how we recover
# it. A "Temporary Crazy Egg" analytics <script> in baseof.html is unconditional
# (not gated behind HUGO_ENV) and is stripped the same way.
#
# The docs content also references ~570 unique screenshots/diagrams under
# /media/docs/... and a couple under /static/img/... -- these are served from a
# separate grafana.com media host, not part of docs-base at all, so they're
# fetched and vendored too (verified via `curl -I` against a live URL during
# investigation: 200, image/*). Any image query-string width variant
# (?w=320/550/...) is generated by the theme's responsive image shortcode from
# a single underlying file; nginx's `try_files` on default.conf matches on URI
# path only, so serving that one vendored file per path satisfies every width
# variant without needing an image-resizing proxy.
RUN set -uo pipefail; \
    BASE="https://grafana.com"; \
    DIST="/hugo/dist"; \
    FAILED=0; \
    download() { \
      local urlpath="$1"; \
      local clean="${urlpath%%#*}"; clean="${clean%%\?*}"; \
      [ -z "$clean" ] && return 0; \
      local dest="$DIST$clean"; \
      [ -f "$dest" ] && return 0; \
      mkdir -p "$(dirname "$dest")"; \
      if curl -fsSL --retry 3 "$BASE$clean" -o "$dest"; then return 0; \
      else echo "WARN: failed to fetch $BASE$clean" >&2; rm -f "$dest"; FAILED=$((FAILED+1)); return 1; fi; \
    }; \
    normalize() { node -e "console.log(require('path').posix.normalize(process.argv[1]))" "$1"; }; \
    echo "== [1/6] Vendoring core theme CSS files =="; \
    CSS_PATHS="/web/fonts.min.css /web/fonts/font-awesome/css/font-awesome.min.css /web/app.min.css /web/shared.min.css /web/marketing-ui.min.css"; \
    for p in $CSS_PATHS; do download "$p"; done; \
    echo "== [2/6] Vendoring assets referenced from within those CSS files (fonts, backgrounds, icons) =="; \
    for p in $CSS_PATHS; do \
      dir="$(dirname "$p")"; f="$DIST$p"; \
      [ -f "$f" ] || continue; \
      grep -oE "url\(['\"]?[^)'\"]*['\"]?\)" "$f" | sed -E "s/^url\(['\"]?//; s/['\"]?\)\$//" | sort -u | while IFS= read -r ref; do \
        [ -z "$ref" ] && continue; \
        case "$ref" in \
          data:*) continue ;; \
          http://*|https://*) continue ;; \
          /*) abspath="$ref" ;; \
          *) abspath="$(normalize "$dir/$ref")" ;; \
        esac; \
        download "$abspath"; \
      done; \
    done; \
    echo "== [3/6] Vendoring doc screenshot/diagram images (/media/docs/*, /static/img/*) =="; \
    grep -rhoE '(/media/docs/[a-zA-Z0-9._/@-]+\.[a-zA-Z0-9]+)|(/static/img/[a-zA-Z0-9._/@-]+\.[a-zA-Z0-9]+)' "$DIST/docs/grafana/latest" | sort -u | while IFS= read -r ref; do download "$ref"; done; \
    echo "== [4/6] Rewriting HTML references from https://grafana.com/web/ to local /web/ =="; \
    grep -rl "https://grafana\.com/web/" "$DIST" 2>/dev/null | while IFS= read -r file; do sed -i -E 's#https://grafana\.com/web/#/web/#g' "$file"; done; \
    echo "== [5/6] Stripping external, unvendored <script> tags (app.js/banner.js/marked.js/marketing-ui.js + crazyegg analytics) =="; \
    grep -rl -E '<script[^>]*src=https://(grafana\.com/web|script\.crazyegg\.com)/[^ >]*[^>]*></script>' "$DIST" 2>/dev/null | while IFS= read -r file; do \
      sed -i -E 's#<script[^>]*src=https://grafana\.com/web/[^ >]*[^>]*></script>##g; s#<script[^>]*src=https://script\.crazyegg\.com/[^ >]*[^>]*></script>##g' "$file"; \
    done; \
    echo "== [6/6] De-lazifying images (see note below) =="; \
    grep -rl -E 'data-src=' "$DIST/docs/grafana/latest" 2>/dev/null | while IFS= read -r file; do \
      sed -i -E \
        -e 's/(class="[^"]*)\blazyload\b ?/\1/g' \
        -e 's/data-srcset="/srcset="/g' \
        -e 's/data-src="/src="/g' \
        -e 's/data-sizes="[^"]*"//g' \
        "$file"; \
    done; \
    echo "Vendoring complete. Failed downloads: $FAILED"

# Why de-lazify (step 6): the theme lazy-loads every figure/screenshot with the
# lazysizes-style `<img class="lazyload" data-src="...">` convention (opacity:0
# via CSS until a JS lazyloader swaps data-src -> src). That loader ships only
# inside the app.js bundle we just deliberately excluded, so without this
# rewrite every content image would silently never appear. Rewriting
# data-src(set) -> src(set) and dropping the lazyload class makes every image
# load eagerly with zero JS involved -- the right tradeoff for a local/offline
# mirror where lazy-loading is a performance nicety, not a requirement.
#
# Net effect of shipping no theme JS at all: no client-side search/AI-chat
# modal, no copy-to-clipboard/tab-switcher interactivity, no analytics of any
# kind (Rudderstack/Hotjar/GA/Marketo/Adobe Target/Crazy Egg all absent) -- and
# no marketing mega-nav/footer chrome, which the upstream "docs" HUGO_ENV branch
# already omits by design (baseof.html: "don't load footer on docs preview",
# navbar gated the same way). Page content, the real left-hand docs
# sidebar/TOC/breadcrumbs, and full theme CSS styling all render normally.

# Strip the marketing/analytics <script> tags. Step 4 above rewrote every
# `https://grafana.com/web/` reference to a local `/web/` path BEFORE the
# original strip step ran, so that strip (which matched the grafana.com URL)
# no longer matched and the tags survived pointing at `/web/{app,banner,marked,
# marketing-ui}.js` -- local paths we deliberately never vendor (they carry
# Rudderstack/Hotjar/GA/Marketo/Adobe Target/etc.), so they 404 on every page.
# Remove those <script> tags outright here, matching the post-rewrite local
# form. The vendored `/web/*.css` <link> tags use `href=`, not `src=`, so they
# are untouched. Guard that no `/web/` script tag survives.
RUN find /hugo/dist -type f -name "*.html" -exec \
      sed -i -E 's#<script[^>]*src=/web/[^>]*></script>##g' {} + && \
    ! grep -rqE '<script[^>]*src=/web/' /hugo/dist || \
      (echo "FATAL: a /web/ marketing <script> tag survived" >&2 && exit 1)

# Sanity check: fail the build loudly if Hugo didn't actually produce the docs.
RUN test -f /hugo/dist/docs/grafana/latest/index.html || (echo "Grafana docs build produced no index.html" >&2 && exit 1)

# --- Stage 2: Serve the offline site ---
FROM nginx:alpine

COPY --from=builder /hugo/dist /usr/share/nginx/html
COPY default.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
